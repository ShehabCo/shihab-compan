# Super Platform - Environment Variables Template
# Copy this file to .env.local and fill in your values

# ============================================================
# SUPABASE CONFIGURATION
# ============================================================
# Get these from: https://supabase.com/dashboard

# Public URL of your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anonymous/public key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (KEEP PRIVATE - backend only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# STRIPE CONFIGURATION
# ============================================================
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe publishable key (safe to expose in frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_123456789...

# Stripe secret key (KEEP PRIVATE - backend only)
STRIPE_SECRET_KEY=sk_test_123456789...

# Stripe webhook secret (for webhook signature verification)
STRIPE_WEBHOOK_SECRET=whsec_test_123456789...

# ============================================================
# GROQ AI CONFIGURATION
# ============================================================
# Get this from: https://console.groq.com/keys

# Groq API key (KEEP PRIVATE)
GROQ_API_KEY=gsk_...

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================

# Public application URL
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
# Values: development, production, test
NODE_ENV=development

# ============================================================
# OPTIONAL: MONITORING & ANALYTICS
# ============================================================

# Sentry error tracking (optional)
# NEXT_PUBLIC_SENTRY_DSN=https://...

# PostHog analytics (optional)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ============================================================
# NOTES
# ============================================================
# 1. Never commit .env.local to Git
# 2. Keep all PRIVATE keys secure (don't share)
# 3. Use different keys for development and production
# 4. Rotate keys regularly
# 5. Never hardcode sensitive values in code
#
# Development vs Production:
# - Development: Use Stripe TEST keys (pk_test_, sk_test_)
# - Production: Use Stripe LIVE keys (pk_live_, sk_live_)
#
# Getting Your Keys:
# 1. Supabase: https://supabase.com/dashboard → Settings → API
# 2. Stripe: https://dashboard.stripe.com/apikeys
# 3. Groq: https://console.groq.com/keys
#
# ============================================================
