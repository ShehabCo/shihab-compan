# Production Environment Configuration
# ====================================

# Supabase (Production)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication (Vercel Deployment)
NEXTAUTH_SECRET=prod_secret_key_at_least_32_chars
NEXTAUTH_URL=https://your-domain.com

# Stripe (Production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_live_key
STRIPE_SECRET_KEY=sk_live_your_live_secret

# AI Services (Production)
OPENAI_API_KEY=sk_prod_openai_key
ANTHROPIC_API_KEY=prod_anthropic_key

# Database (Production RDS/Cloud)
DATABASE_URL=postgresql://produser:prodpass@prod-db.aws.rds.amazonaws.com:5432/super_app_prod

# Redis (Managed Service)
REDIS_URL=redis://:password@prod-redis.aws.elasticache.amazonaws.com:6379

# File Storage (S3 / R2)
STORAGE_BUCKET_NAME=super-app-prod
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA_prod_access_key
AWS_SECRET_ACCESS_KEY=prod_secret_access_key

# Analytics
NEXT_PUBLIC_GA_ID=G_PRODUCTION_ID

# API Configuration
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
API_SECRET=prod_api_secret_key_strong

# Feature Flags
ENABLE_AI_FEATURES=true
ENABLE_SELLER_DASHBOARD=true
ENABLE_ADMIN_PANEL=true
ENABLE_ADVANCED_ANALYTICS=true

# Environment
NODE_ENV=production
NEXT_PUBLIC_ENV=production

# Monitoring & Logging
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
LOG_LEVEL=info
